# Copy to ~/.codex/bridges/codex-lark-minimal/config.env and chmod 600.
# The installer (./install.sh) does this for you on first run.

# --- Feishu / Lark app credentials -----------------------------------------
# Create a custom app at https://open.feishu.cn (or https://open.larksuite.com
# for global Lark) with Bot capability + im.message.receive_v1 event +
# long-connection event delivery. Required for real mode.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Feishu (CN): https://open.feishu.cn   Lark (global): https://open.larksuite.com
FEISHU_DOMAIN=https://open.feishu.cn

# --- Safety: discovery vs real mode ----------------------------------------
# Defaults are deliberately safe. To go live: set DRY_RUN=0 AND ALLOW_ALL=0
# AND populate at least one allowlist below.
FEISHU_CODEX_DRY_RUN=1
FEISHU_CODEX_ALLOW_ALL=1

# Comma-separated. Get sender_id / chat_id from the bridge log after the bot
# receives a test message in dry-run mode.
FEISHU_CODEX_ALLOWED_SENDERS=
FEISHU_CODEX_ALLOWED_CHATS=

# --- Routing ---------------------------------------------------------------
# Trigger word the bot listens for. e.g. "codex help"
FEISHU_CODEX_TRIGGER_PREFIX=codex

# REQUIRED. Comma-separated alias=path pairs. Only these directories can be
# targeted from chat. Replace the examples with your real project paths.
# Example: FEISHU_CODEX_WORKSPACES=myproj=/Users/you/Projects/myproj,site=/Users/you/Projects/site
FEISHU_CODEX_WORKSPACES=
FEISHU_CODEX_DEFAULT_WORKSPACE=

# --- Codex CLI invocation --------------------------------------------------
FEISHU_CODEX_CODEX_BIN=codex
FEISHU_CODEX_SANDBOX=workspace-write
FEISHU_CODEX_APPROVAL=never
FEISHU_CODEX_MODEL=
FEISHU_CODEX_PROFILE=
FEISHU_CODEX_EXTRA_ARGS=
FEISHU_CODEX_MAX_RUNNING=2
FEISHU_CODEX_MAX_PROMPT_CHARS=6000
FEISHU_CODEX_REPLY=1

# --- Paths (uncomment to override defaults) --------------------------------
# Defaults: $HOME/.codex/bridges/codex-lark-minimal and $HOME/.codex
# FEISHU_CODEX_HOME=
# CODEX_HOME=
