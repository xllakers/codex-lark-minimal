# codex-lark-minimal config
#
# Lives at ~/.codex/bridges/codex-lark-minimal/config.env (chmod 600).
# `./install.sh` and `codex-lark setup` write this for you. You only need
# to hand-edit if you skipped the wizard.
#
# Run `codex-lark doctor` after editing to verify.

# ============================================================================
# REQUIRED
# ============================================================================

# 1. Feishu/Lark app credentials. Create a custom app with Bot capability,
#    im.message.receive_v1 event subscribed via long-connection delivery,
#    and BOTH of these permissions (Feishu split the old im:message scope):
#      - im:message.p2p_msg:readonly  (required to receive DMs)
#      - im:message:send_as_bot       (required to reply)
#    Then publish a version. The wizard prompts only for these two values.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 2. Allowlist — at least one of senders or chats must be non-empty to go
#    live. An empty allowlist keeps the daemon in dry-run automatically.
#    `codex-lark setup` populates these for you by capturing the first message
#    you DM the bot during the discovery window.
FEISHU_CODEX_ALLOWED_SENDERS=
FEISHU_CODEX_ALLOWED_CHATS=

# 3. Workspaces the bot can drive. Comma-separated alias=path. The wizard
#    does NOT prompt for these (keep setup short); add them post-setup with:
#      codex-lark configure --set FEISHU_CODEX_WORKSPACES=myproj=/path/to/myproj
#    Without workspaces, `codex help` / `codex recent` etc. still work, but
#    `codex <alias>: <task>` has nothing to route to.
FEISHU_CODEX_WORKSPACES=

# ============================================================================
# OPTIONAL — defaults shown
# ============================================================================

# Lark global (vs Feishu mainland): https://open.larksuite.com
FEISHU_DOMAIN=https://open.feishu.cn

# Default workspace alias when chat omits one (e.g. `codex run tests`).
# Defaults to the first entry in FEISHU_CODEX_WORKSPACES.
FEISHU_CODEX_DEFAULT_WORKSPACE=

# Trigger word the bot listens for. e.g. "codex help"
FEISHU_CODEX_TRIGGER_PREFIX=codex

# Force dry-run even with an allowlist filled in (useful for staging).
# Leave unset to let the allowlist drive the mode.
# FEISHU_CODEX_DRY_RUN=1

# Codex CLI invocation
FEISHU_CODEX_CODEX_BIN=codex
FEISHU_CODEX_SANDBOX=workspace-write
FEISHU_CODEX_APPROVAL=never
FEISHU_CODEX_MODEL=
FEISHU_CODEX_PROFILE=
FEISHU_CODEX_EXTRA_ARGS=
FEISHU_CODEX_MAX_RUNNING=2
FEISHU_CODEX_MAX_PROMPT_CHARS=6000
FEISHU_CODEX_REPLY=1
# Set to 0 to stop the bridge from appending a one-line row to
# $CODEX_HOME/session_index.jsonl after a bridge-spawned job captures its
# Codex session id. The append is what lets `codex status <thread name>`
# resolve bridge-spawned threads; disable only if you don't want the bridge
# touching Codex's index file.
FEISHU_CODEX_SESSION_INDEX_APPEND=1

# Paths (uncomment to override defaults under $HOME/.codex/)
# FEISHU_CODEX_HOME=
# CODEX_HOME=
